{
    "kind": "collectionType",
    "collectionName": "partners",
    "info": {
        "singularName": "partner",
        "pluralName": "partners",
        "displayName": "Partner",
        "description": "Project partner organisations"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "maxLength": 150
        },
        "logo": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "website_url": {
            "type": "string"
        },
        "description": {
            "type": "text",
            "maxLength": 600
        },
        "order": {
            "type": "integer",
            "default": 0
        },
        "is_active": {
            "type": "boolean",
            "default": true
        },
        "partner_type": {
            "type": "enumeration",
            "enum": [
                "lead",
                "government",
                "un-agency",
                "civil-society",
                "private-sector",
                "donor"
            ],
            "default": "un-agency"
        }
    }
}